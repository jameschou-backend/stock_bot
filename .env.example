FINMIND_TOKEN=__在這裡填token__

# Telegram Bot（選填）
# 1. 找 @BotFather → /newbot 取得 TOKEN
# 2. 啟動 Bot 後對它發任意訊息，再執行：
#    curl https://api.telegram.org/bot<TOKEN>/getUpdates
#    從回應的 message.chat.id 取得 CHAT_ID
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DB_DIALECT=mysql
DB_HOST=127.0.0.1
DB_PORT=3307
DB_NAME=stock_bot
DB_USER=__在這裡填使用者__
DB_PASSWORD=__在這裡填密碼__
TOPN=20
LABEL_HORIZON_DAYS=20
TRAIN_LOOKBACK_YEARS=5
# 排程時間建議 17:30 以後（台股 13:30 收盤後 ~3-4 小時 TWSE 才更新所有 endpoint，
# 含三大法人 T86、融資融券 MI_MARGN、本益比 BWIBBU_d）。
# 凌晨跑會拿不到當天資料（TWSE 給的最新交易日仍是前一天）。
SCHEDULE_TIME=17:30
TZ=Asia/Taipei
DASHBOARD_SHOW_ML=0

OPENAI_API_KEY=__填你的key__
OPENAI_MODEL=gpt-4.1-mini
AI_ASSIST_ENABLED=0
AI_ASSIST_MAX_CODE_LINES=200
AI_ASSIST_MAX_LOG_LINES=200

BOOTSTRAP_DAYS=365
MIN_AVG_TURNOVER=0.5
FALLBACK_DAYS=10
MARKET_FILTER_ENABLED=true
MARKET_FILTER_MA_DAYS=60
MARKET_FILTER_BEAR_TOPN=10
REGIME_DETECTOR=ma
STOPLOSS_PCT=-0.07
TRANSACTION_COST_PCT=0.001425
BACKTEST_POSITION_SIZING=vol_inverse
BACKTEST_TRAILING_STOP_PCT=-0.12
STRATEGY_WEIGHTS_BULL={"MomentumTrend":0.6,"MeanReversion":0.2,"DefensiveLowVol":0.2}
STRATEGY_WEIGHTS_BEAR={"MomentumTrend":0.2,"MeanReversion":0.3,"DefensiveLowVol":0.5}
EVAL_TOPK_LIST=10,20
FINMIND_REQUESTS_PER_HOUR=6000
CHUNK_DAYS=180
INSTITUTIONAL_BULK_CHUNK_DAYS=90
MARGIN_BULK_CHUNK_DAYS=90
FINMIND_RETRY_MAX=3
FINMIND_RETRY_BACKOFF=1.0

# Sponsor ingest 開關（預設 on，向後相容）
# 設 off / false / 0 可跳過 6 個 per-stock 重型 sponsor ingest
# (broker_trades, holding_dist, kbar_features, per, securities_lending, quarterly_fundamental)
# 每日省 ~12,000 FinMind API calls。這些 ingest 的特徵目前全部位於 _PRUNE_SET，未進入生產模型，停跑無 alpha 損失。
# gov_bank / fear_greed 為日頻單 call 成本低，不受此開關影響仍會執行。
SPONSOR_INGEST=on

# ── Ingest 後端切換（Phase 2b）─────────────────────────────────────────
# 每個 ingest 都有獨立開關，預設 finmind（向後相容）。
# 切到 twse 改用 TWSE/TPEx 官方 API（免費、無 rate limit、無需 token）。
# 適用於：FinMind sponsor 到期後想全免費運作，或想避開 rate limit。
# 切換建議：先切 prices 觀察 1 週確認 features 正常，再切其他 3 個。
# 隨時可改回 finmind（或刪掉這幾行）恢復原行為。
#
# INGEST_PRICES_SOURCE=twse          # 改抓 TWSE STOCK_DAY_ALL + TPEx daily_close_quotes
# INGEST_INSTITUTIONAL_SOURCE=twse   # 改抓 TWSE T86 + TPEx 3insti（OpenAPI 沒有 T86，走 legacy）
# INGEST_MARGIN_SHORT_SOURCE=twse    # 改抓 TWSE MI_MARGN + TPEx margin_balance
# INGEST_PER_SOURCE=twse             # 改抓 TWSE BWIBBU_d + TPEx peQryDate

# TWSE/TPEx client 行為微調（通常不用動）
# TWSE_REQUEST_DELAY=1.5             # 每個 HTTP request 最少間隔秒數（防 rate limit）
# TWSE_TIMEOUT=30                    # HTTP 超時秒數
# TWSE_MAX_RETRIES=3                 # 5xx / 429 重試次數
# TWSE_RETRY_BACKOFF=2.0             # 指數退避基底秒數
